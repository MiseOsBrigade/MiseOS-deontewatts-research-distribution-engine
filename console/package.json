{
  "name": "research-upload-console",
  "version": "0.4.0",
  "private": true,
  "engines": {
    "node": "24.x",
    "npm": ">=11"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit:production": "npm audit --omit=dev --audit-level=moderate",
    "verify": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.21",
    "postcss": "8.5.10",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  },
  "overrides": {
    "postcss": "8.5.10",
    "next": {
      "postcss": "8.5.10"
    }
  }
}
